MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/hello_neighbour?retryWrites=true&w=majority
JWT_SECRET=change_this_to_a_long_random_string
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB Atlas Admin API — for auto IP whitelisting on dev start
# Get these from Atlas → Access Manager → API Keys
ATLAS_PUBLIC_KEY=
ATLAS_PRIVATE_KEY=
# Get this from Atlas → Project Settings
ATLAS_PROJECT_ID=
